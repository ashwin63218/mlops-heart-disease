{
  "title": "Heart Disease API — MLOps Monitor",
  "uid": "heart-disease-mlops",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["mlops", "fastapi", "heart-disease"],
  "annotations": { "list": [] },
  "panels": [

    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(http_requests_total{job=\"heart-disease-api\"})",
        "legendFormat": "Total Requests",
        "refId": "A"
      }],
      "datasource": "Prometheus"
    },

    {
      "id": 2,
      "title": "Request Rate (req/sec)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "reqps",
          "decimals": 3
        }
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\"}[1m]))",
        "legendFormat": "req/s",
        "refId": "A"
      }],
      "datasource": "Prometheus"
    },

    {
      "id": 3,
      "title": "P50 / P95 / P99 Latency (seconds)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"heart-disease-api\"}[5m]))",
        "legendFormat": "Error Rate",
        "refId": "A"
      }],
      "datasource": "Prometheus"
    },

    {
      "id": 5,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", handler=\"/predict\"}[1m]))",
          "legendFormat": "POST /predict",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", handler=\"/health\"}[1m]))",
          "legendFormat": "GET /health",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\"}[1m]))",
          "legendFormat": "All endpoints",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 6,
      "title": "Latency Percentiles Over Time — /predict",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[2m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[2m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"heart-disease-api\", handler=\"/predict\"}[2m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 7,
      "title": "HTTP Status Code Breakdown",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", status_code=\"200\"}[1m]))",
          "legendFormat": "200 OK",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", status_code=\"422\"}[1m]))",
          "legendFormat": "422 Validation Error",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"heart-disease-api\", status_code=\"503\"}[1m]))",
          "legendFormat": "503 Service Unavailable",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 8,
      "title": "Active Requests (In-Flight)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [{
        "expr": "sum(http_requests_in_progress{job=\"heart-disease-api\"})",
        "legendFormat": "In-flight requests",
        "refId": "A"
      }],
      "datasource": "Prometheus"
    }

  ]
}